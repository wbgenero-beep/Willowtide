# Release signing — EXAMPLE. Copy to `keystore.properties` (git-ignored) and fill in.
# William creates the keystore and owns these values; they are never committed.
#
#   keytool -genkey -v -keystore bountu-upload.keystore -alias bountu \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile may be an absolute path or a path relative to android/app/.
storeFile=../../bountu-upload.keystore
storePassword=CHANGE_ME
keyAlias=bountu
keyPassword=CHANGE_ME
